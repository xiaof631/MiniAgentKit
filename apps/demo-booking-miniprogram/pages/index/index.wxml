<view class="page">
  <view class="header">
    <image class="app-icon" src="/assets/icon.png" mode="aspectFit"></image>
    <text class="title">约小帮</text>
    <text class="subtitle">用 AI 帮用户预约服务、查询档期并确认提交</text>
  </view>

  <view class="panel">
    <view class="panel-title">验证项</view>
    <view wx:for="{{checks}}" wx:key="*this" class="check-row">
      <text class="dot"></text>
      <text class="check-text">{{item}}</text>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">测试话术</view>
    <text class="prompt">帮我预约明天下午 3 点的颈部理疗体验</text>
  </view>
</view>
